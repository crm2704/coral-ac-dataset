{
  "@context": [
    "http://www.w3.org/ns/odrl.jsonld",
    "https://raw.githubusercontent.com/ODRE-Framework/hospital-rls-dataset/refs/heads/main/context.json"
  ],
  "@type": "odrl:Set",
  "uid": "ex:e29c824e-7e51-417a-b8a2-f1b2b6cfd1c9",
  "rdfs:label" : "Policy 05",
  "permission": [
    {
      "@type": "odrl:Permission",
      "assigner": {
        "@type": [
          "odrl:Party",
          "sch:Hospital"
        ],
        "uid": "ex:hopital-organization",
        "rdfs:description" : "A specific hospital that owns this policy"
      },
      "assignee": {
        "@type": [
          "odrl:PartyCollection",
          "sch:Physician"
        ],
        "uid": "ex:groups/medical-staff",
        "rdfs:description" : "Anyone who belongs to the medical staff"
      },
      "action": "modify",
      "target": "db:ClinicalRecords",
      "constraint": [
        {
          "@type": "odrl:Constraint",
          "leftOperand": "ex:request/P05/param-physician-identity",
          "operator": "odrl:isAnyOf",
          "rightOperand": "db:ClinicalRecords?patient_id"
        },{
          "@type": "odrl:Constraint",
          "leftOperand": "ex:request/P05/param-patient-identity",
          "operator": "odrl:isAnyOf",
          "rightOperand": "db:ClinicalRecords?patient_id"
        }
      ]
    }
  ]
}
